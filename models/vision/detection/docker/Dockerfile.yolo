FROM ghcr.io/quic/cloud_ai_triton_server:1.21.4.0

# Create dedicated environment
RUN python3 -m venv /opt/yolo-env
ENV PATH="/opt/yolo-env/bin:$PATH"

# Upgrade pip first
RUN /opt/yolo-env/bin/pip install --no-cache-dir --upgrade pip

# Install YOLO dependencies
COPY requirements.txt /tmp/requirements.txt
RUN /opt/yolo-env/bin/pip install --no-cache-dir -r /tmp/requirements.txt

WORKDIR /models
