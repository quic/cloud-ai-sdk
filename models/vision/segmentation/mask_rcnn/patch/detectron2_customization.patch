+def _fp16_clamp_model_inplace(module: nn.Module, min_abs: float) -> int:
+    """Clamp tiny (nonzero) float weights/buffers to reduce FP16 underflow.
+
+    This modifies the PyTorch model *before export*.
+    """
+    if min_abs <= 0:
+        raise ValueError("min_abs must be > 0")
+
+    total = 0
+
+    def _clamp_tensor_(t: torch.Tensor) -> int:
+        if not torch.is_floating_point(t):
+            return 0
+        with torch.no_grad():
+            mask = (t != 0) & (t.abs() < min_abs)
+            cnt = int(mask.sum().item())
+            if cnt:
+                t[mask] = t[mask].sign() * min_abs
+            return cnt
+
+    for _, p in module.named_parameters(recurse=True):
+        total += _clamp_tensor_(p)
+
+    for _, b in module.named_buffers(recurse=True):
+        total += _clamp_tensor_(b)
+
+    return total
+
